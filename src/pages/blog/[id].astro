---
import { getBlogDetail, getCategoryList, getBlogList } from "@libs/microcms.ts";
import Layout from "@layouts/Layout.astro";
import BlogPost from "@components/BlogPost.astro";
import BlogList from "@components/BlogList.astro";
import CategoryList from "@components/CategoryList.astro";
export const prerender = false;

const { id } = Astro.params;
if (!id) throw new Error("id is required");

const url = new URL(Astro.url.href);
const draftKey = url.searchParams.get("draftKey");

const cachePolicies = {
  noCache: "no-store, no-cache, max-age=0, must-revalidate",
  publicIsr: "public, s-maxage=180, stale-while-revalidate=180",
};

const cachePolicy = draftKey ? cachePolicies.noCache : cachePolicies.publicIsr;
Astro.response.headers.set("Cache-Control", cachePolicy);

const blog = await getBlogDetail(id, draftKey ? { draftKey } : {});

// カテゴリーリストを取得
const { contents: categories } = await getCategoryList();

// 同じカテゴリの関連記事を取得（現在の記事を除外）
let relatedBlogs = [];
if (blog?.category && blog.category.length > 0) {
  const catId = blog.category[0].id;
  try {
    const { contents: allBlogs } = await getBlogList({ limit: 100 });
    // クライアント側でフィルタリング：同じカテゴリで現在の記事を除外
    relatedBlogs = allBlogs
      .filter(
        (b) =>
          b.category?.some((c) => c.id === catId) && b.id !== id
      )
      .slice(0, 4);
  } catch (error) {
    console.error("Failed to fetch related blogs:", error);
  }
}

const Meta = {
  title: blog ? blog.title : "ブログ記事が見つかりません",
  image: blog.thumbnail
    ? blog.thumbnail.url
    : new URL("/assets/images/og.png", Astro.site),
  ogType: "article",
  description: blog.description,
};
---

<Layout Meta={Meta}>
  <div class="space-y-8">
    {
      blog ? (
        <BlogPost blog={blog} />
      ) : (
        <p class="text-center text-lg">このブログ記事は存在しません。</p>
      )
    }

    {
      relatedBlogs.length > 0 ? (
        <section class="space-y-4">
          <h2 class="text-2xl font-semibold">同じカテゴリの記事</h2>
          <BlogList blogs={relatedBlogs} />
        </section>
      ) : null
    }
  </div>

  <div class="space-y-8">
    <CategoryList categories={categories} />
  </div>
</Layout>
